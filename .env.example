# SMTP configuration for the quote form (/api/quote).
# Copy this file to .env.local and fill in real values.
# Until these are set, quote submissions are logged server-side and the
# form still shows the success screen (delivered:false).

SMTP_HOST=mail.yourhost.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=sales@kaneimpex.com
SMTP_PASS=your-mailbox-password

# Where new quote notifications are sent (defaults to SMTP_USER).
QUOTE_TO=sales@kaneimpex.com
# From header for outgoing mail (defaults to "Kaneimpex Website" <SMTP_USER>).
QUOTE_FROM="Kaneimpex Website" <sales@kaneimpex.com>
